# Скопируй в .env и при необходимости поменяй значения.
# В dev значения по умолчанию совпадают с docker-compose.

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=bt
POSTGRES_PASSWORD=bt_dev_password
POSTGRES_DB=bt_payments
POSTGRES_PORT=5432

# --- Prisma ---
DATABASE_URL="postgresql://bt:bt_dev_password@localhost:5432/bt_payments?schema=public"

# --- Сессии / авторизация ---
# Длинная случайная строка для подписи сессионных cookie. ОБЯЗАТЕЛЬНО сменить в проде.
SESSION_SECRET="change-me-to-a-long-random-string-in-production"

# Провайдер авторизации: credentials (MVP) | sso (на будущее)
AUTH_PROVIDER=credentials
